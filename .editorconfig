# HPC-AI-Optimization-Lab EditorConfig
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C/C++/CUDA files
[*.{c,cc,cpp,cxx,h,hh,hpp,hxx,cu,cuh}]
indent_size = 4
max_line_length = 100

# CMake files
[CMakeLists.txt]
indent_size = 4

[*.cmake]
indent_size = 4

# Python files
[*.py]
indent_size = 4
max_line_length = 88

# Python stub files
[*.pyi]
indent_size = 4

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Shell scripts
[*.sh]
indent_size = 2

# Dockerfile
[Dockerfile*]
indent_size = 4

# Makefile (requires tabs)
[Makefile]
indent_style = tab

# Git config files
[.git*]
indent_size = 4

# GitHub templates
[.github/**]
indent_size = 2
